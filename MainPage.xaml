<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SMSForwarder.MainPage"
             Title="Configuración">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <!-- Cabecera -->
            <VerticalStackLayout Spacing="8">
                <Label x:Name="TitleLabel"
                       Text="Configuración"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                       HorizontalOptions="Center"/>
                <Label x:Name="SubtitleLabel"
                       Text="Configura los números donde reenviar SMS"
                       Style="{StaticResource HintText}"
                       FontSize="14"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Selector de idioma -->
            <VerticalStackLayout Spacing="8">
                <Label x:Name="LanguageLabel"
                       Text="Idioma"
                       Style="{StaticResource BodyText}"
                       FontAttributes="Bold"/>
                <Border Style="{StaticResource Card}" Padding="8,2">
                    <Picker x:Name="LanguagePicker"
                            Title="Elige el idioma de la aplicación"
                            FontSize="14"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                            SelectedIndexChanged="OnLanguagePickerChanged">
                        <Picker.Items>
                            <x:String>Español</x:String>
                            <x:String>English</x:String>
                        </Picker.Items>
                    </Picker>
                </Border>
            </VerticalStackLayout>

            <!-- Entrada de numero -->
            <VerticalStackLayout Spacing="12">
                <Border Style="{StaticResource Card}" Padding="4">
                    <Entry x:Name="PhoneEntry"
                           Placeholder="Ej: +34 600 123 456"
                           BackgroundColor="Transparent"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                           PlaceholderColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}"
                           FontSize="16"/>
                </Border>

                <!-- Botones de accion -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button x:Name="AddButton"
                            Grid.Column="0"
                            Text="📝 Agregar Número"
                            Clicked="OnAddClicked"
                            Style="{StaticResource PrimaryButton}"
                            FontSize="14"/>

                    <Button x:Name="ContactsButton"
                            Grid.Column="1"
                            Text="👥 Desde Contactos"
                            Clicked="OnSelectFromContactsClicked"
                            Style="{StaticResource SuccessButton}"/>
                </Grid>
            </VerticalStackLayout>

            <!-- Lista de numeros -->
            <VerticalStackLayout Spacing="12">
                <Label x:Name="NumbersListLabel"
                       Text="Números configurados"
                       Style="{StaticResource CardTitle}"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                       HorizontalOptions="Center"
                       Margin="0,8,0,0"/>

                <CollectionView x:Name="PhoneList" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}" Margin="0,4">
                                <SwipeView>
                                    <SwipeView.RightItems>
                                        <SwipeItems>
                                            <SwipeItem x:Name="DeleteSwipeItem"
                                                       Text="Eliminar"
                                                       BackgroundColor="{StaticResource Danger}"
                                                       Invoked="OnDeleteClicked"
                                                       CommandParameter="{Binding .}"/>
                                        </SwipeItems>
                                    </SwipeView.RightItems>
                                    <Grid Padding="16,12" ColumnDefinitions="Auto,*,Auto">
                                        <Border Grid.Column="0"
                                                BackgroundColor="{StaticResource PrimaryLight}"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 16"
                                                WidthRequest="32"
                                                HeightRequest="32"
                                                VerticalOptions="Center">
                                            <Label Text="📱"
                                                   FontSize="16"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                        </Border>
                                        <Label Grid.Column="1"
                                               Text="{Binding .}"
                                               Style="{StaticResource BodyText}"
                                               FontSize="16"
                                               VerticalOptions="Center"
                                               Margin="12,0,0,0"/>
                                        <Label Grid.Column="2"
                                               Text="›"
                                               FontSize="22"
                                               Style="{StaticResource HintText}"
                                               VerticalOptions="Center"/>
                                    </Grid>
                                </SwipeView>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- Informacion de ayuda -->
            <Border Style="{StaticResource Card}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource PageBackgroundDark}}"
                    Padding="16"
                    Margin="0,8,0,0">
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="InfoTitle"
                           Text="💡 Información"
                           Style="{StaticResource CardTitle}"
                           FontSize="14"/>
                    <Label x:Name="InfoText"
                           Text="• Los SMS recibidos se reenviarán automáticamente a estos números&#x0a;• Puedes escribir números manualmente o seleccionarlos desde tus contactos&#x0a;• Para configurar permisos avanzados, ve a la sección Diagnósticos&#x0a;• Desliza hacia la izquierda en un número para eliminarlo"
                           Style="{StaticResource HintText}"
                           LineBreakMode="WordWrap"/>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
