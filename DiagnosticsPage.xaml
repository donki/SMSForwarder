<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SMSForwarder.DiagnosticsPage"
             Title="Diagnósticos">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <!-- Cabecera -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Diagnósticos"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                       HorizontalOptions="Center" />
                <Label Text="Monitoreo y estado del sistema"
                       Style="{StaticResource HintText}"
                       FontSize="14"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Tarjetas de estado -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" RowSpacing="12">
                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="16">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="🔒" FontSize="24" HorizontalOptions="Center" />
                        <Label Text="Permisos" Style="{StaticResource BodyText}" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label x:Name="PermissionsStatus" Text="Verificando..." Style="{StaticResource HintText}" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource Card}" Padding="16">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="📱" FontSize="24" HorizontalOptions="Center" />
                        <Label Text="Números" Style="{StaticResource BodyText}" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label x:Name="PhonesCount" Text="0" Style="{StaticResource HintText}" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Permisos -->
            <VerticalStackLayout Spacing="12">
                <Label Text="Configuración de Permisos"
                       Style="{StaticResource CardTitle}"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                       HorizontalOptions="Center"
                       Margin="0,8,0,0" />

                <Button Text="🔍 Verificar Estado de Permisos"
                        Clicked="OnCheckPermissionsClicked"
                        Style="{StaticResource PrimaryButton}"
                        FontSize="14"
                        HeightRequest="44" />

                <Button Text="⚙️ Configurar Todos los Permisos"
                        Clicked="OnConfigureAllPermissionsClicked"
                        Style="{StaticResource SuccessButton}"
                        HeightRequest="44" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Grid.Column="0"
                            Text="🔋 Batería"
                            Clicked="OnBatteryOptimizationClicked"
                            Style="{StaticResource AccentButton}"
                            FontSize="12"
                            HeightRequest="40" />

                    <Button Grid.Column="1"
                            Text="🚀 Autostart"
                            Clicked="OnAutostartClicked"
                            Style="{StaticResource OutlineButton}"
                            FontSize="12"
                            HeightRequest="40" />
                </Grid>

                <Border Style="{StaticResource Card}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource PageBackgroundDark}}"
                        Padding="12">
                    <Label Text="💡 Para un funcionamiento óptimo, configure todos los permisos. Esto asegura que la aplicación pueda recibir y reenviar SMS incluso cuando esté en segundo plano."
                           Style="{StaticResource HintText}"
                           LineBreakMode="WordWrap" />
                </Border>
            </VerticalStackLayout>

            <!-- Herramientas -->
            <VerticalStackLayout Spacing="12">
                <Label Text="Herramientas de Diagnóstico"
                       Style="{StaticResource CardTitle}"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                       HorizontalOptions="Center"
                       Margin="0,16,0,0" />

                <Button Text="🔄 Actualizar Estado"
                        Clicked="OnRefreshClicked"
                        Style="{StaticResource PrimaryButton}"
                        FontSize="14"
                        HeightRequest="44" />

                <Button Text="📤 Enviar SMS de Prueba"
                        Clicked="OnTestSmsClicked"
                        Style="{StaticResource OutlineButton}"
                        HeightRequest="44" />
            </VerticalStackLayout>

            <!-- Registro -->
            <VerticalStackLayout Spacing="12">
                <Label Text="Registro de actividad"
                       Style="{StaticResource CardTitle}"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                       HorizontalOptions="Center" />

                <Border Style="{StaticResource Card}" Padding="12">
                    <ScrollView HeightRequest="180">
                        <Label x:Name="LogsLabel"
                               Text="Sin actividad reciente..."
                               FontSize="12"
                               FontFamily="Monospace"
                               Style="{StaticResource BodyText}"
                               LineBreakMode="WordWrap" />
                    </ScrollView>
                </Border>

                <Button Text="Limpiar registro"
                        Clicked="OnClearLogsClicked"
                        Style="{StaticResource OutlineButton}"
                        HeightRequest="40" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
