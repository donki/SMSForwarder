<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SMSForwarder.Pages.AboutPage"
             Title="Acerca de"
             BackgroundColor="#F8F9FA">

    <ScrollView>
        <StackLayout Padding="16"
                     Spacing="16">

            <!-- Header Card -->
            <Frame BackgroundColor="White"
                   CornerRadius="12"
                   HasShadow="True"
                   Padding="0">
                <StackLayout Padding="24,20"
                             Spacing="12">
                    <Label
                        Text="📱"
                        FontSize="60"
                        HorizontalOptions="Center"/>

                    <Label
                        Text="SMS Forwarder"
                        FontSize="28"
                        FontAttributes="Bold"
                        TextColor="#2C3E50"
                        HorizontalOptions="Center"/>

                    <Label
                        Text="Versión 2026.06.13.2"
                        FontSize="16"
                        TextColor="#7F8C8D"
                        HorizontalOptions="Center"/>

                    <Label
                        Text="Reenvía automáticamente tus SMS a otros números de teléfono"
                        FontSize="14"
                        TextColor="#95A5A6"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"/>

                </StackLayout>
            </Frame>

            <!-- Contact Card -->
            <Frame BackgroundColor="White"
                   CornerRadius="12"
                   HasShadow="True"
                   Padding="0">
                <StackLayout Padding="25,20"
                             Spacing="15">
                    <Label
                        Text="📧 Contacto"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="#3498DB"/>

                    <Button
                        Text="jsoladelarosa@gmail.com"
                        FontSize="14"
                        BackgroundColor="Transparent"
                        TextColor="#3498DB"
                        BorderColor="#3498DB"
                        BorderWidth="1"
                        CornerRadius="8"
                        MinimumHeightRequest="48"
                        LineBreakMode="WordWrap"
                        Padding="12,10"
                        Clicked="OnContactEmailClicked"
                        HorizontalOptions="Fill">
                        <Button.Shadow>
                            <Shadow Brush="#3498DB"
                                    Opacity="0.2"
                                    Radius="4"
                                    Offset="0,2"/>
                        </Button.Shadow>
                    </Button>

                    <Label
                        Text="Toca para enviar un correo electrónico"
                        FontSize="12"
                        TextColor="#7F8C8D"
                        HorizontalOptions="Center"/>
                </StackLayout>
            </Frame>

            <!-- Support Card -->
            <Frame BackgroundColor="White"
                   CornerRadius="12"
                   HasShadow="True"
                   Padding="0">
                <StackLayout Padding="25,20"
                             Spacing="15">
                    <Label
                        Text="☕ Apoya el Desarrollo"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="#E67E22"/>

                    <Button
                        Text="Ko-fi.com - Invítame un café"
                        FontSize="14"
                        BackgroundColor="#E67E22"
                        TextColor="White"
                        CornerRadius="8"
                        MinimumHeightRequest="48"
                        LineBreakMode="WordWrap"
                        Padding="12,10"
                        Clicked="OnDonationClicked"
                        HorizontalOptions="Fill">
                        <Button.Shadow>
                            <Shadow Brush="#E67E22"
                                    Opacity="0.3"
                                    Radius="8"
                                    Offset="0,4"/>
                        </Button.Shadow>
                    </Button>

                    <Label
                        Text="Tu apoyo ayuda a mantener y mejorar la aplicación"
                        FontSize="12"
                        TextColor="#7F8C8D"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"/>
                </StackLayout>
            </Frame>

            <!-- Legal Disclaimer Card -->
            <Frame BackgroundColor="White"
                   CornerRadius="12"
                   HasShadow="True"
                   Padding="0">
                <StackLayout Padding="25,20"
                             Spacing="15">
                    <Label
                        Text="⚖️ Aviso Legal"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="#E74C3C"/>

                    <Frame BackgroundColor="#FDF2F2"
                           CornerRadius="8"
                           Padding="15"
                           HasShadow="False">
                        <StackLayout Spacing="10">
                            <Label
                                Text="Este software se proporciona 'tal como está', sin garantías de ningún tipo. El usuario es responsable del uso adecuado de la aplicación y del cumplimiento de las leyes locales."
                                FontSize="13"
                                LineHeight="1.4"
                                TextColor="#2C3E50"/>

                            <Label
                                Text="En ningún caso los autores serán responsables de daños directos, indirectos, incidentales o consecuentes que resulten del uso de este software."
                                FontSize="13"
                                LineHeight="1.4"
                                TextColor="#2C3E50"/>

                            <Frame BackgroundColor="#E74C3C"
                                   CornerRadius="6"
                                   Padding="12"
                                   HasShadow="False">
                                <Label
                                    Text="⚠️ Uso bajo su propio riesgo"
                                    FontSize="13"
                                    FontAttributes="Bold"
                                    LineHeight="1.4"
                                    TextColor="White"
                                    HorizontalOptions="Center"/>
                            </Frame>
                        </StackLayout>
                    </Frame>
                </StackLayout>
            </Frame>

            <!-- Language Selection Card -->
            <Frame BackgroundColor="White"
                   CornerRadius="12"
                   HasShadow="True"
                   Padding="0">
                <StackLayout Padding="25,20"
                             Spacing="15">
                    <Label
                        Text="🌐 Idioma / Language"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="#9B59B6"/>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">
                        <Button Grid.Column="0"
                                Text="🇪🇸 Español"
                                FontSize="14"
                                BackgroundColor="#9B59B6"
                                TextColor="White"
                                CornerRadius="8"
                                MinimumHeightRequest="48"
                                LineBreakMode="WordWrap"
                                Padding="10,10"
                                Clicked="OnSpanishClicked"/>

                        <Button Grid.Column="1"
                                Text="🇺🇸 English"
                                FontSize="14"
                                BackgroundColor="Transparent"
                                TextColor="#9B59B6"
                                BorderColor="#9B59B6"
                                BorderWidth="1"
                                CornerRadius="8"
                                MinimumHeightRequest="48"
                                LineBreakMode="WordWrap"
                                Padding="10,10"
                                Clicked="OnEnglishClicked"/>
                    </Grid>

                    <Label
                        Text="Selecciona tu idioma preferido"
                        FontSize="12"
                        TextColor="#7F8C8D"
                        HorizontalOptions="Center"/>
                </StackLayout>
            </Frame>

            <!-- Back Button -->
            <Button
                Text="← Volver"
                FontSize="16"
                FontAttributes="Bold"
                BackgroundColor="#3498DB"
                TextColor="White"
                CornerRadius="10"
                MinimumHeightRequest="50"
                Clicked="OnBackClicked"
                HorizontalOptions="Fill"
                Margin="0,10,0,20">
                <Button.Shadow>
                    <Shadow Brush="#3498DB"
                            Opacity="0.3"
                            Radius="8"
                            Offset="0,4"/>
                </Button.Shadow>
            </Button>

        </StackLayout>
    </ScrollView>

</ContentPage>