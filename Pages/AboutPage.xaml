<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SMSForwarder.Pages.AboutPage"
             Title="Acerca de">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <!-- Cabecera -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Padding="24,20" Spacing="12">
                    <Image Source="smsforwadericon.png"
                           WidthRequest="72"
                           HeightRequest="72"
                           HorizontalOptions="Center"/>

                    <Label Text="SMS Forwarder"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                           HorizontalOptions="Center"/>

                    <Label x:Name="VersionLabel"
                           Text="Versión"
                           Style="{StaticResource HintText}"
                           FontSize="16"
                           HorizontalOptions="Center"/>

                    <Label x:Name="DescriptionLabel"
                           Text="Reenvía automáticamente tus SMS a otros números de teléfono"
                           Style="{StaticResource HintText}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Border>

            <!-- Contacto -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Padding="25,20" Spacing="15">
                    <Label x:Name="ContactTitleLabel"
                           Text="Contacto"
                           Style="{StaticResource CardTitle}"/>

                    <Button Text="jsoladelarosa@gmail.com"
                            Style="{StaticResource OutlineButton}"
                            LineBreakMode="WordWrap"
                            Padding="12,10"
                            Clicked="OnContactEmailClicked"
                            HorizontalOptions="Fill"/>

                    <Label x:Name="ContactInstructionLabel"
                           Text="Toca para enviar un correo electrónico"
                           Style="{StaticResource HintText}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>

            <!-- Apoyo -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Padding="25,20" Spacing="15">
                    <Label x:Name="SupportTitleLabel"
                           Text="Apoya el Desarrollo"
                           Style="{StaticResource CardTitle}"
                           TextColor="{StaticResource Accent}"/>

                    <Button x:Name="DonationButton"
                            Text="Ko-fi.com - Invítame un café"
                            Style="{StaticResource AccentButton}"
                            LineBreakMode="WordWrap"
                            Padding="12,10"
                            Clicked="OnDonationClicked"
                            HorizontalOptions="Fill"/>

                    <Label x:Name="SupportDescLabel"
                           Text="Tu apoyo ayuda a mantener y mejorar la aplicación"
                           Style="{StaticResource HintText}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Border>

            <!-- Idioma -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Padding="25,20" Spacing="15">
                    <Label x:Name="LanguageTitleLabel"
                           Text="Idioma"
                           Style="{StaticResource CardTitle}"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button x:Name="SpanishButton"
                                Grid.Column="0"
                                Text="🇪🇸 Español"
                                Style="{StaticResource PrimaryButton}"
                                FontSize="14"
                                LineBreakMode="WordWrap"
                                Padding="10,10"
                                Clicked="OnSpanishClicked"/>

                        <Button x:Name="EnglishButton"
                                Grid.Column="1"
                                Text="🇺🇸 English"
                                Style="{StaticResource OutlineButton}"
                                FontSize="14"
                                LineBreakMode="WordWrap"
                                Padding="10,10"
                                Clicked="OnEnglishClicked"/>
                    </Grid>

                    <Label x:Name="LanguageDescLabel"
                           Text="Selecciona tu idioma preferido"
                           Style="{StaticResource HintText}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>

            <!-- Privacidad -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Padding="25,20" Spacing="10">
                    <Label x:Name="PrivacyTitleLabel"
                           Text="Privacidad"
                           Style="{StaticResource CardTitle}"/>

                    <Label x:Name="PrivacyTextLabel"
                           Text="Esta aplicación no recopila tus datos personales ni los envía a los desarrolladores. La información se procesa en tu dispositivo para la función propia de la app."
                           Style="{StaticResource BodyText}"
                           FontSize="13"
                           LineHeight="1.4"/>
                </VerticalStackLayout>
            </Border>

            <!-- Licencia -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Padding="25,20" Spacing="10">
                    <Label x:Name="LicenseTitleLabel"
                           Text="Licencia"
                           Style="{StaticResource CardTitle}"/>

                    <Label x:Name="LicenseTextLabel"
                           Text="Esta aplicación es software libre distribuido bajo licencia MIT."
                           Style="{StaticResource BodyText}"
                           FontSize="13"
                           LineHeight="1.4"/>

                    <Label Text="MIT License · Copyright © 2026 Socratic"
                           Style="{StaticResource HintText}"
                           FontSize="11"/>
                </VerticalStackLayout>
            </Border>

            <!-- Aviso legal -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Padding="25,20" Spacing="15">
                    <Label x:Name="LegalTitleLabel"
                           Text="Aviso Legal"
                           Style="{StaticResource CardTitle}"
                           TextColor="{StaticResource Danger}"/>

                    <Border StrokeThickness="0"
                            Padding="15"
                            BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource PageBackgroundDark}}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="10">
                            <Label x:Name="LegalText1Label"
                                   Text="Este software se proporciona «tal cual», sin garantías de ningún tipo. El usuario es responsable del uso adecuado de la aplicación y del cumplimiento de las leyes locales."
                                   Style="{StaticResource BodyText}"
                                   FontSize="13"
                                   LineHeight="1.4"/>

                            <Label x:Name="LegalText2Label"
                                   Text="En ningún caso los autores serán responsables de daños directos, indirectos, incidentales o consecuentes que resulten del uso de este software."
                                   Style="{StaticResource BodyText}"
                                   FontSize="13"
                                   LineHeight="1.4"/>

                            <Border StrokeThickness="0"
                                    Padding="12"
                                    BackgroundColor="{StaticResource Danger}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="6" />
                                </Border.StrokeShape>
                                <Label x:Name="WarningLabel"
                                       Text="⚠️ Uso bajo su propio riesgo"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       LineHeight="1.4"
                                       TextColor="{StaticResource White}"
                                       HorizontalOptions="Center"/>
                            </Border>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Volver -->
            <Button x:Name="BackButton"
                    Text="← Volver"
                    Style="{StaticResource PrimaryButton}"
                    HeightRequest="50"
                    Clicked="OnBackClicked"
                    HorizontalOptions="Fill"
                    Margin="0,10,0,20"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
