<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SMSForwarder.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SMSForwarder"
    xmlns:pages="clr-namespace:SMSForwarder.Pages"
    Shell.FlyoutBehavior="Flyout"
    Title="SMS Forwarder"
    Shell.ForegroundColor="{StaticResource Primary}"
    Shell.TitleColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
    Shell.UnselectedColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}"
    Shell.DisabledColor="{StaticResource SeparatorLight}"
    FlyoutBackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
    FlyoutWidth="260">

    <!-- Icono y título en la barra superior -->
    <Shell.TitleView>
        <Grid ColumnDefinitions="Auto,*"
              Padding="0">
            <Image Source="smsforwadericon.png"
                   HeightRequest="24"
                   VerticalOptions="Center"/>
            <Label Grid.Column="1"
                   Text="SMS Forwarder"
                   FontSize="18"
                   FontAttributes="Bold"
                   VerticalOptions="Center"
                   Margin="8,0,0,0"/>
        </Grid>
    </Shell.TitleView>

    <!-- Header del menú con safe area -->
    <Shell.FlyoutHeader>
        <Grid BackgroundColor="{StaticResource Primary}"
              HeightRequest="140"
              Padding="20,40,20,20">
            <VerticalStackLayout VerticalOptions="Center"
                                 Spacing="8">
                <Label x:Name="HeaderTitle"
                       Text="SMS Forwarder"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="{StaticResource OnPrimary}"
                       HorizontalOptions="Start"/>
                <Label x:Name="HeaderSubtitle"
                       Text="Control de mensajes"
                       FontSize="12"
                       TextColor="{StaticResource OnPrimary}"
                       Opacity="0.9"
                       HorizontalOptions="Start"/>
            </VerticalStackLayout>
        </Grid>
    </Shell.FlyoutHeader>

    <FlyoutItem x:Name="SettingsItem"
                Title="Configuración"
                Icon="settings.svg">
        <ShellContent
            Title="Configuración"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage"/>
    </FlyoutItem>

    <FlyoutItem x:Name="DiagnosticsItem"
                Title="Diagnósticos"
                Icon="diagnostics.svg">
        <ShellContent
            Title="Diagnósticos"
            ContentTemplate="{DataTemplate local:DiagnosticsPage}"
            Route="DiagnosticsPage"/>
    </FlyoutItem>

    <FlyoutItem x:Name="AboutItem"
                Title="Acerca de"
                Icon="about.svg">
        <ShellContent
            Title="Acerca de"
            ContentTemplate="{DataTemplate pages:AboutPage}"
            Route="AboutPage"/>
    </FlyoutItem>

    <!-- Footer del menú -->
    <Shell.FlyoutFooter>
        <Grid BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
              HeightRequest="60"
              Padding="20">
            <Label x:Name="FooterVersion"
                   Text="v2026.07.17.0 - sOCratic"
                   FontSize="10"
                   Style="{StaticResource HintText}"
                   VerticalOptions="Center"
                   HorizontalOptions="Center"/>
        </Grid>
    </Shell.FlyoutFooter>

</Shell>
