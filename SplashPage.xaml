<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SMSForwarder.SplashPage"
             BackgroundColor="{StaticResource Primary}"
             NavigationPage.HasNavigationBar="False">

    <Grid>
        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="24">

            <!-- Logo en pastilla -->
            <Border BackgroundColor="{StaticResource White}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20"
                    WidthRequest="120"
                    HeightRequest="120"
                    HorizontalOptions="Center"
                    x:Name="LogoFrame">
                <Border.Shadow>
                    <Shadow Brush="{StaticResource Black}" Opacity="0.2" Radius="15" Offset="0,8" />
                </Border.Shadow>
                <Image Source="smsforwadericon.png"
                       WidthRequest="80"
                       HeightRequest="80"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>

            <Label Text="SMS Forwarder"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="{StaticResource White}"
                   HorizontalOptions="Center"
                   x:Name="TitleLabel" />

            <Label Text="Reenvío inteligente"
                   FontSize="14"
                   TextColor="#E3F0FC"
                   HorizontalOptions="Center"
                   x:Name="SubtitleLabel" />

            <VerticalStackLayout Spacing="12" Margin="0,32,0,0">
                <ActivityIndicator IsRunning="True"
                                   Color="{StaticResource White}"
                                   WidthRequest="32"
                                   HeightRequest="32"
                                   HorizontalOptions="Center" />
            </VerticalStackLayout>

        </VerticalStackLayout>

        <Label Text="sOCratic"
               FontSize="12"
               TextColor="#C8E4FA"
               HorizontalOptions="Center"
               VerticalOptions="End"
               Margin="0,0,0,40" />

    </Grid>
</ContentPage>
